#!/usr/bin/env bash
#
#MISE description="Apply home-manager configuration"
#USAGE flag "--online" help="Apply using internet"
#

set -euo pipefail

# Unrice before switching to avoid ricing and home-manager fighting over the same files
if command -v hmrice &>/dev/null; then
  if hmrice status | grep -q RICING; then
    hmrice unrice
  fi
fi

ONLINE_FLAG="${usage_online:-false}"

if command -v nh &>/dev/null; then
  NH_OPTS=(--backup-extension bak --configuration "$(whoami)" . -- --show-trace)
  [[ "$ONLINE_FLAG" != "true" ]] && NH_OPTS+=(--offline)
  nh home switch "${NH_OPTS[@]}"
else
  HM_OPTS=(-b bak --flake ".#$(whoami)")
  [[ "$ONLINE_FLAG" != "true" ]] && HM_OPTS+=(--option substituters "")
  home-manager switch "${HM_OPTS[@]}"
fi
