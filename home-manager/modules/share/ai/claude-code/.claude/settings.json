{
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(backlog:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jira issue:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(tmux:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Edit",
      "Read",
      "Skill(brainstorm)",
      "Skill(clear-writing)",
      "Skill(continuous-learning)",
      "Skill(create-skill)",
      "Skill(implementation-planner)",
      "Skill(jira)",
      "Skill(web-research)",
      "Skill(kotlin-mentor)",
      "Skill(rails-mentor)",
      "Skill(ruby-mentor)",
      "Write",
      "WebFetch",
      "mcp__atlassian__fetch",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getConfluencePage",
      "mcp__datadog__*",
      "mcp__memory__*",
      "mcp__sentry__*",
      "mcp__sequentialthinking__*"
    ],
    "deny": []
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pi-sidekick hook session-start --registry .sandbox/session.json"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/ai/hooks/pre-tool-safety/main.rb"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/cc_statusline.rb",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "doctolib-productivity@doctolib": true
  },
  "effortLevel": "high"
}
