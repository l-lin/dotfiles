{
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(backlog:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jira issue:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(tmux:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Edit",
      "Read",
      "Skill(brainstorm)",
      "Skill(clear-writing)",
      "Skill(continuous-learning)",
      "Skill(create-skill)",
      "Skill(implementation-planner)",
      "Skill(jira)",
      "Skill(web-research)",
      "Skill(kotlin-mentor)",
      "Skill(rails-mentor)",
      "Skill(ruby-mentor)",
      "Write",
      "WebFetch",
      "mcp__atlassian__fetch",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getConfluencePage",
      "mcp__datadog__*",
      "mcp__memory__*",
      "mcp__sentry__*",
      "mcp__sequentialthinking__*"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pi-sidekick hook session-start --registry .sandbox/session.json"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pi-sidekick hook permission-request --registry .sandbox/session.json"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/cc_statusline.rb",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "doctolib-productivity@doctolib": true,
    "doctolib-c3@doctolib": true,
    "claude-md-management@claude-plugins-official": true
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "theme": "light",
  "autoCompactEnabled": false,
  "tui": "fullscreen"
}
