{
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(backlog:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jira issue:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(tmux:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Edit",
      "Read",
      "Skill(brainstorm)",
      "Skill(clear-writing)",
      "Skill(continuous-learning)",
      "Skill(create-skill)",
      "Skill(implementation-planner)",
      "Skill(jira)",
      "Skill(web-research)",
      "Skill(kotlin-mentor)",
      "Skill(rails-mentor)",
      "Skill(ruby-mentor)",
      "Write",
      "WebFetch",
      "mcp__atlassian__fetch",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getConfluencePage",
      "mcp__datadog__*",
      "mcp__sentry__*",
      "mcp__fe4102e0-e2ea-4246-8736-e9872b03890c__slack_send_message"
    ],
    "deny": []
  },
  "model": "sonnet[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/ai/hooks/bad-bash/bad-bash.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/cc_statusline.rb",
    "padding": 0
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "doctolib-productivity@doctolib": true,
    "doctolib-c3@doctolib": true,
    "claude-md-management@claude-plugins-official": true,
    "doctolib-analytics-agent@doctolib": true,
    "doctolib-doctoboot@doctolib": true
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "tui": "fullscreen",
  "theme": "light",
  "autoCompactEnabled": false
}
