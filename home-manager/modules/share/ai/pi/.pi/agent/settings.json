{
  "lastChangelogVersion": "0.75.4",
  "theme": "light",
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.4",
  "enableInstallTelemetry": false,
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "xhigh",
  "compaction": {
    "enabled": false
  },
  "hideThinkingBlock": false,
  "extensionSettings": {
    "askUserQuestion": {
      "enabled": true
    },
    "copilotUsage": {
      "visible": false
    },
    "webSearch": {
      "enabled": true
    },
    "webFetch": {
      "enabled": true
    },
    "modelSelector": {
      "keybind": "alt-m"
    },
    "sandbox": {
      "enabled": true
    },
    "damageControl": {
      "enabled": true
    }
  },
  "packages": []
}
