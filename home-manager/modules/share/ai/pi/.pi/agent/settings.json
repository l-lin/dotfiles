{
  "lastChangelogVersion": "0.65.2",
  "theme": "light",
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-4.1",
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "xhigh",
  "compaction": {
    "enabled": false
  },
  "hideThinkingBlock": false,
  "extensionSettings": {
    "askUserQuestion": {
      "enabled": true
    },
    "copilotUsage": {
      "visible": false
    },
    "lspDiagnostics": {
      "enabled": true
    },
    "subagent": {
      "enabled": false,
      "sources": [
        "~/.pi/agent/subagents",
        "./.pi/subagents"
      ],
      "maxParallel": 5,
      "userSystemPrompt": {
        "path": "~/.config/ai/system-prompt.md"
      }
    },
    "webSearch": {
      "enabled": true
    },
    "webFetch": {
      "enabled": true
    },
    "modelSelector": {
      "keybind": "alt-m"
    },
    "sandbox": {
      "enabled": true
    }
  },
  "packages": []
}