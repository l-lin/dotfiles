{
  "lastChangelogVersion": "0.55.1",
  "theme": "light",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-6",
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "off",
  "copilotUsageVisible": false,
  "compaction": {
    "enabled": false
  },
  "subagent": {
    "sources": [
      "~/.pi/agent/subagents",
      "./.pi/subagents",
      "./.claude/agents"
    ],
    "maxParallel": 4,
    "userSystemPrompt": {
      "enabled": false,
      "path": "~/.config/ai/system-prompt.md"
    }
  },
  "hideThinkingBlock": false
}
