{
  "lastChangelogVersion": "0.81.1",
  "theme": "light",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-opus-4-8",
  "enableInstallTelemetry": false,
  "treeFilterMode": "user-only",
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "high",
  "compaction": {
    "enabled": false
  },
  "hideThinkingBlock": false,
  "extensionSettings": {
    "askUserQuestion": {
      "enabled": true
    },
    "copilotUsage": {
      "visible": false
    },
    "webSearch": {
      "enabled": true
    },
    "webFetch": {
      "enabled": true
    },
    "modelSelector": {
      "keybind": "alt-m"
    },
    "sandbox": {
      "enabled": true
    },
    "damageControl": {
      "enabled": false
    },
    "mcpAdapter": {
      "enabled": false
    },
    "awesomeEditor": {
      "mode": "emacs"
    }
  },
  "packages": [
    "npm:pi-mcp-adapter"
  ]
}
