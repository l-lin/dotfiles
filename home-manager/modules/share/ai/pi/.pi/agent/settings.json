{
  "lastChangelogVersion": "0.62.0",
  "theme": "light",
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.4",
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "high",
  "compaction": {
    "enabled": false
  },
  "hideThinkingBlock": false,
  "extensionSettings": {
    "askUserQuestion": {
      "enabled": true
    },
    "copilotUsage": {
      "visible": false
    },
    "lspDiagnostics": {
      "enabled": true
    },
    "subagent": {
      "enabled": true,
      "sources": [
        "~/.pi/agent/subagents",
        "./.pi/subagents"
      ],
      "maxParallel": 5,
      "userSystemPrompt": {
        "path": "~/.config/ai/system-prompt.md"
      }
    },
    "webSearch": {
      "enabled": false
    },
    "webFetch": {
      "enabled": false
    },
    "modelSelector": {
      "models": [
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-4.1"
      ],
      "keybind": "alt-m"
    }
  }
}
