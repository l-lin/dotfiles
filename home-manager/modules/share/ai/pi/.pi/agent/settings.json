{
  "lastChangelogVersion": "0.61.1",
  "theme": "light",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-6",
  "skills": [
    "~/.config/ai/skills"
  ],
  "prompts": [
    "~/.config/ai/commands"
  ],
  "quietStartup": true,
  "defaultThinkingLevel": "high",
  "compaction": {
    "enabled": false
  },
  "hideThinkingBlock": false,
  "extensionSettings": {
    "askUserQuestion": {
      "enabled": true
    },
    "copilotUsage": {
      "visible": false
    },
    "lspDiagnostics": {
      "enabled": true
    },
    "subagent": {
      "enabled": true,
      "sources": [
        "~/.pi/agent/subagents",
        "./.pi/subagents"
      ],
      "maxParallel": 5,
      "userSystemPrompt": {
        "path": "~/.config/ai/system-prompt.md"
      }
    },
    "webSearch": {
      "enabled": false
    },
    "webFetch": {
      "enabled": false
    }
  }
}