#!/usr/bin/env zsh
#
# Get a single Google Chrome cookie value (macOS only).
#
# Cookies live in an encrypted SQLite DB per Chrome profile; browser_cookie3
# reads it and decrypts values using the "Chrome Safe Storage" Keychain key.
#
# Usage: get-chrome-cookie-value <profile> <domain> <cookie>
#   <profile>  Chrome profile directory, e.g. "Default" or "Profile 1"
#   <domain>   cookie domain, e.g. "www.example.org"
#   <cookie>   cookie name, e.g. "_cookie_foobar"
#

if [[ $# -ne 3 ]]; then
  print -u2 "Usage: get-chrome-cookie-value <profile> <domain> <cookie>"
  return 1
fi

uv run --quiet --with browser_cookie3 python3 - "$@" <<'PY'
import base64
import binascii
import json
import os
import subprocess
import sys
import time

import browser_cookie3

JWT_EXPIRATION_LEEWAY_SECONDS = 60
RETRY_TIMEOUT_SECONDS = 60
RETRY_INTERVAL_SECONDS = 1

profile, domain, name = sys.argv[1:4]
cookie_file = os.path.expanduser(
    f"~/Library/Application Support/Google/Chrome/{profile}/Cookies"
)

def decode_jwt_expiration(cookie_value: str):
    parts = cookie_value.split(".")
    if len(parts) != 3:
        return None

    payload_segment = parts[1]
    payload_padding = "=" * (-len(payload_segment) % 4)

    try:
        payload_bytes = base64.urlsafe_b64decode(payload_segment + payload_padding)
        payload = json.loads(payload_bytes.decode())
    except (binascii.Error, json.JSONDecodeError, UnicodeDecodeError):
        return None

    if not isinstance(payload, dict):
        return None

    expiration = payload.get("exp")
    if isinstance(expiration, bool) or not isinstance(expiration, (int, float)):
        return None

    return float(expiration)


def get_usable_cookie_value():
    jar = browser_cookie3.chrome(cookie_file=cookie_file, domain_name=domain)
    now = time.time()
    usable_value = None

    for cookie in jar:
        if cookie.name != name:
            continue

        expiration = decode_jwt_expiration(cookie.value)
        if expiration is None:
            continue

        if expiration > now + JWT_EXPIRATION_LEEWAY_SECONDS:
            usable_value = cookie.value

    return usable_value


def open_domain_once():
    try:
        subprocess.run(
            ["open", f"https://{domain}/"],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError:
        pass


value = get_usable_cookie_value()
if value is not None:
    print(value)
    raise SystemExit(0)

open_domain_once()
deadline = time.monotonic() + RETRY_TIMEOUT_SECONDS

while time.monotonic() < deadline:
    remaining = deadline - time.monotonic()
    time.sleep(min(RETRY_INTERVAL_SECONDS, remaining))

    value = get_usable_cookie_value()
    if value is not None:
        print(value)
        raise SystemExit(0)

sys.exit("timed out waiting for a usable cookie")
PY
